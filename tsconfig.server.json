{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "noEmit": false
  },
  "include": [
    "server/**/*.ts",
    "src/automation.ts",
    "src/domain.ts"
  ]
}
